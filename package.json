{
  "name": "vlc-js",
  "version": "1.0.0",
  "description": "VLC media player compiled to WebAssembly via Emscripten",
  "private": true,
  "scripts": {
    "start": "node server.js",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:browser": "vitest run tests/mxf-browser-playback.test.js"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "jsdom": "^28.1.0",
    "playwright-core": "^1.58.2",
    "typescript": "^5.7",
    "vitest": "^4.0.18"
  }
}
